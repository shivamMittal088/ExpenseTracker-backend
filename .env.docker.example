# Required — MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/expense-tracker

# Optional observability (leave blank if not using Axiom)
AXIOM_TOKEN=
AXIOM_ORG_ID=
AXIOM_DATASET=

# Optional Cloudinary (leave blank if not using avatar uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
